# Deployer wallet — NEVER commit a real value
# Generate via: cast wallet new (use a fresh wallet, NOT your main wallet)
PRIVATE_KEY=0x

# ── Ethereum Sepolia (chainId 11155111) ──────────────────────────
# Primary testnet for drain't — full EIP-7702 support post-Pectra
ETHEREUM_SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
# Alternative: https://eth-sepolia.g.alchemy.com/v2/<YOUR_KEY>
# Faucet: https://sepoliafaucet.com

# ── Ethereum Mainnet (chainId 1) ─────────────────────────────────
# REQUIRED for Best 1Shot Relayer track (mainnet only)
# Budget ~$10 USDC for demo tx via 1Shot
ETHEREUM_MAINNET_RPC_URL=https://eth.llamarpc.com
# Alternative: https://eth-mainnet.g.alchemy.com/v2/<YOUR_KEY>

# ── Etherscan unified API key (works for both mainnet + sepolia) ─
ETHERSCAN_API_KEY=

# ── Base Sepolia (chainId 84532) — optional multi-chain ──────────
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASESCAN_API_KEY=
# Faucet: https://www.alchemy.com/faucets/base-sepolia

# ── Arbitrum Sepolia (chainId 421614) — optional ─────────────────
ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
ARBISCAN_API_KEY=
# Faucet: https://www.alchemy.com/faucets/arbitrum-sepolia

# ── Optimism Sepolia (chainId 11155420) — optional ───────────────
OPTIMISM_SEPOLIA_RPC_URL=https://sepolia.optimism.io
OPSCAN_API_KEY=
# Faucet: https://www.alchemy.com/faucets/optimism-sepolia
